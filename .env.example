# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Postgres, matches docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=bongofleet
DB_PASSWORD=bongofleet_dev_password
DB_NAME=bongofleet
DATABASE_URL=postgresql://bongofleet:bongofleet_dev_password@localhost:5432/bongofleet

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- pgAdmin (docker-compose only, not used by the app) ---
PGADMIN_EMAIL=admin@bongofleet.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Auth (placeholders - fill in when auth milestone starts) ---
JWT_SECRET=replace_with_a_long_random_value
JWT_EXPIRES_IN=1d

# --- Payments (placeholders - fill in when payments milestone starts) ---
# e.g. mobile money provider keys go here once that integration is scoped
