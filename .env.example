# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Postgres, matches docker-compose.yml) ---
# Default host port is 5433, not Postgres's usual 5432 - a native Windows
# PostgreSQL install commonly already owns 5432 and silently intercepts
# connections meant for this container, causing confusing auth failures.
DB_HOST=localhost
DB_PORT=5433
DB_USER=bongofleet
DB_PASSWORD=bongofleet_dev_password
DB_NAME=bongofleet
DATABASE_URL=postgresql://bongofleet:bongofleet_dev_password@localhost:5433/bongofleet

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- pgAdmin (docker-compose only, not used by the app) ---
PGADMIN_EMAIL=admin@bongofleet.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Auth ---
JWT_ACCESS_SECRET=replace_with_a_long_random_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_value
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated allowlist of origins allowed to call the API with credentials.
# Required in production (the app refuses to start without it there). Left unset
# in development, it falls back to the local dashboard/mobile dev origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Payments (placeholders - fill in when payments milestone starts) ---
# e.g. mobile money provider keys go here once that integration is scoped

# --- Outgoing email (document expiry alerts) ---
# Leave SMTP_HOST blank for "log-only" mode: alert emails are written to the
# app log instead of sent - safe for development. For real email, point these
# at any SMTP relay (SES, Mailgun, Zoho, Gmail app password, ...).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=BongoFleet <no-reply@bongofleet.app>

# --- Document expiry scan ---
# Daily digest of expired / expiring-soon documents, one email per fleet.
DOCUMENT_EXPIRY_ALERT_DAYS=30
DOCUMENT_EXPIRY_CRON=0 7 * * *
DOCUMENT_EXPIRY_TZ=Africa/Dar_es_Salaam

# --- File uploads (rider/motorcycle/guarantor documents) ---
# Directory uploaded files are written to. In docker-compose this is a named
# volume mounted at /workspace/uploads so files survive container restarts;
# locally it defaults to ./uploads under packages/backend (gitignored).
UPLOADS_DIR=./uploads
