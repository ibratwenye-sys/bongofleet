# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Postgres, matches docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=bongofleet
DB_PASSWORD=bongofleet_dev_password
DB_NAME=bongofleet
DATABASE_URL=postgresql://bongofleet:bongofleet_dev_password@localhost:5432/bongofleet

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- pgAdmin (docker-compose only, not used by the app) ---
PGADMIN_EMAIL=admin@bongofleet.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Auth ---
JWT_ACCESS_SECRET=replace_with_a_long_random_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_value
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated allowlist of origins allowed to call the API with credentials.
# Required in production (the app refuses to start without it there). Left unset
# in development, it falls back to the local dashboard/mobile dev origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Payments (placeholders - fill in when payments milestone starts) ---
# e.g. mobile money provider keys go here once that integration is scoped

# --- File uploads (rider/motorcycle/guarantor documents) ---
# Directory uploaded files are written to. In docker-compose this is a named
# volume mounted at /workspace/uploads so files survive container restarts;
# locally it defaults to ./uploads under packages/backend (gitignored).
UPLOADS_DIR=./uploads
