generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  RIDER
  MECHANIC

  @@map("user_role")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("payment_status")
}

enum MotorcycleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED

  @@map("motorcycle_status")
}

enum DocumentOwnerType {
  RIDER
  MOTORCYCLE
  GUARANTOR

  @@map("document_owner_type")
}

enum DocumentType {
  NATIONAL_ID
  DRIVERS_LICENSE
  LATRA
  INSURANCE
  REGISTRATION_CARD
  GUARANTOR_ID
  VEHICLE_INSPECTION
  ROAD_SAFETY_WEEK
  TBS_CERTIFICATE
  OTHER

  @@map("document_type")
}

enum DocumentAlertKind {
  EXPIRING_SOON
  EXPIRED

  @@map("document_alert_kind")
}

enum PaymentAlertKind {
  NO_PAYMENT
  SHORTFALL

  @@map("payment_alert_kind")
}

/// A fleet-owning company/account. Root of multi-tenancy - every other table
/// scopes its data to a tenantId.
model Tenant {
  id           String   @id @default(cuid())
  name         String
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users             User[]
  riders            Rider[]
  motorcycles       Motorcycle[]
  dailyAssignments  DailyAssignment[]
  dailyPayments     DailyPayment[]
  gpsLocations      GpsLocation[]
  maintenanceLogs   MaintenanceLog[]
  expenses          Expense[]
  guarantors        Guarantor[]
  documents         Document[]
  documentAlerts    DocumentAlert[]
  assignmentAlerts  AssignmentAlert[]

  @@map("tenants")
}

/// Anyone who logs in: owner, manager, rider, or mechanic. Riders get an
/// additional Rider profile (1:1) holding rider-specific fields.
model User {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  email        String
  phone        String
  passwordHash String   @map("password_hash")
  role         UserRole
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  riderProfile             Rider?
  maintenanceLogsPerformed MaintenanceLog[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("users")
}

/// Rider-specific profile, 1:1 with a User whose role is RIDER.
/// Soft-deleted (isActive/deletedAt) rather than hard-deleted so that
/// DailyAssignment/DailyPayment history stays intact.
model Rider {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  userId            String    @unique @map("user_id")
  user              User      @relation(fields: [userId], references: [id])
  licenseNumber     String    @map("license_number")
  nationalId        String?   @map("national_id")
  emergencyContact  String?   @map("emergency_contact")
  isActive          Boolean   @default(true) @map("is_active")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  dailyAssignments DailyAssignment[]
  dailyPayments    DailyPayment[]
  guarantors       Guarantor[]

  @@unique([tenantId, licenseNumber])
  @@index([tenantId])
  @@map("riders")
}

/// A rider's named guarantor (a person who vouches for them), e.g. for a
/// bike-financing arrangement. A rider can have any number of guarantors -
/// no minimum is enforced here (the UI will encourage at least two).
model Guarantor {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  riderId      String    @map("rider_id")
  rider        Rider     @relation(fields: [riderId], references: [id], onDelete: Restrict)
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String
  relationship String?
  nationalId   String?   @map("national_id")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([riderId])
  @@map("guarantors")
}

/// An uploaded document (ID, license, insurance, etc.) belonging to a rider,
/// motorcycle, or guarantor. Polymorphic by ownerType/ownerId rather than a
/// Prisma relation, since it can point at three different tables. File bytes
/// live on disk (see UPLOADS_DIR); only metadata + the storage path live here.
model Document {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  ownerType       DocumentOwnerType @map("owner_type")
  ownerId         String            @map("owner_id")
  docType         DocumentType      @map("doc_type")
  referenceNumber String?           @map("reference_number")
  expiryDate      DateTime?         @map("expiry_date") @db.Date
  fileName        String            @map("file_name")
  mimeType        String            @map("mime_type")
  storageKey      String            @map("storage_key")
  sizeBytes       Int               @map("size_bytes")
  uploadedAt      DateTime          @map("uploaded_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  alerts DocumentAlert[]

  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([tenantId, expiryDate])
  @@map("documents")
}

/// A record that an expiry alert email has already been sent for a document,
/// so the daily scan never notifies the owner twice about the same thing.
/// One row per (document, kind): a document can alert once as EXPIRING_SOON
/// and once again as EXPIRED. Rows cascade-delete with their document, so a
/// replaced (re-uploaded) document alerts afresh on its new expiry date.
model DocumentAlert {
  id         String            @id @default(cuid())
  tenantId   String            @map("tenant_id")
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  documentId String            @map("document_id")
  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  kind       DocumentAlertKind
  sentTo     String            @map("sent_to")
  sentAt     DateTime          @default(now()) @map("sent_at")

  @@unique([documentId, kind])
  @@index([tenantId])
  @@map("document_alerts")
}

/// A fleet motorcycle. Soft-deleted (isActive/deletedAt) rather than hard
/// deleted so MaintenanceLog/Expense/GpsLocation/DailyAssignment history
/// stays intact - relations below use onDelete: Restrict to enforce that
/// at the DB level too.
model Motorcycle {
  id                 String           @id @default(cuid())
  tenantId           String           @map("tenant_id")
  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  registrationNumber String           @map("registration_number")
  make               String?
  model              String?
  year               Int?
  gpsDeviceId        String?          @map("gps_device_id")
  status             MotorcycleStatus @default(ACTIVE)
  isActive           Boolean          @default(true) @map("is_active")
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  dailyAssignments DailyAssignment[]
  gpsLocations     GpsLocation[]
  maintenanceLogs  MaintenanceLog[]
  expenses         Expense[]

  @@unique([tenantId, registrationNumber])
  @@unique([tenantId, gpsDeviceId])
  @@index([tenantId])
  @@map("motorcycles")
}

/// One rider assigned to one motorcycle for one calendar date. A motorcycle
/// can only be assigned to one rider per day, and vice versa (see the two
/// @@unique constraints below).
model DailyAssignment {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  riderId       String     @map("rider_id")
  rider         Rider      @relation(fields: [riderId], references: [id], onDelete: Restrict)
  motorcycleId  String     @map("motorcycle_id")
  motorcycle    Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Restrict)
  assignedDate  DateTime   @map("assigned_date") @db.Date
  targetAmount  Decimal    @map("target_amount") @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  dailyPayments DailyPayment[]
  alert         AssignmentAlert?

  @@unique([tenantId, motorcycleId, assignedDate])
  @@unique([tenantId, riderId, assignedDate])
  @@index([tenantId])
  @@map("daily_assignments")
}

/// A rider's remittance towards a DailyAssignment's targetAmount. One
/// assignment can have multiple payment rows (e.g. a FAILED attempt
/// followed by a successful retry), so this is many-to-one, not 1:1.
model DailyPayment {
  id                String          @id @default(cuid())
  tenantId          String          @map("tenant_id")
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  dailyAssignmentId String          @map("daily_assignment_id")
  dailyAssignment   DailyAssignment @relation(fields: [dailyAssignmentId], references: [id], onDelete: Restrict)
  riderId           String          @map("rider_id")
  rider             Rider           @relation(fields: [riderId], references: [id], onDelete: Restrict)
  amount            Decimal         @db.Decimal(10, 2)
  status            PaymentStatus   @default(PENDING)
  paymentMethod     String?         @map("payment_method")
  paidAt            DateTime?       @map("paid_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([dailyAssignmentId])
  @@map("daily_payments")
}

/// A record that a missed/short payment alert email has been sent for a
/// daily assignment, so the daily scan never nags the owner twice about the
/// same day. One alert ever per assignment (unique dailyAssignmentId): once
/// the owner has been told a day came up short, further chasing happens in
/// the dashboard, not their inbox. Cascade-deletes with its assignment.
model AssignmentAlert {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  dailyAssignmentId String           @unique @map("daily_assignment_id")
  dailyAssignment   DailyAssignment  @relation(fields: [dailyAssignmentId], references: [id], onDelete: Cascade)
  kind              PaymentAlertKind
  targetAmount      Decimal          @map("target_amount") @db.Decimal(10, 2)
  paidAmount        Decimal          @map("paid_amount") @db.Decimal(10, 2)
  sentTo            String           @map("sent_to")
  sentAt            DateTime         @default(now()) @map("sent_at")

  @@index([tenantId])
  @@map("assignment_alerts")
}

/// Append-only GPS ping log for live tracking. No partitioning/retention
/// logic yet (MVP scope) - just indexed for the obvious query pattern
/// (a motorcycle's pings over a time range).
model GpsLocation {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  motorcycleId String     @map("motorcycle_id")
  motorcycle   Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Restrict)
  latitude     Float
  longitude    Float
  speedKmh     Float?     @map("speed_kmh")
  heading      Float?
  recordedAt   DateTime   @map("recorded_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([motorcycleId, recordedAt])
  @@index([tenantId, recordedAt])
  @@map("gps_locations")
}

model MaintenanceLog {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  motorcycleId String     @map("motorcycle_id")
  motorcycle   Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Restrict)
  mechanicId   String?    @map("mechanic_id")
  mechanic     User?      @relation(fields: [mechanicId], references: [id])
  description  String
  cost         Decimal    @db.Decimal(10, 2)
  performedAt  DateTime   @map("performed_at") @db.Date
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([motorcycleId])
  @@map("maintenance_logs")
}

/// Fleet expense, optionally tied to a specific motorcycle (fuel, repair)
/// or tenant-wide (e.g. office rent) when motorcycleId is null.
model Expense {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  motorcycleId String?     @map("motorcycle_id")
  motorcycle   Motorcycle? @relation(fields: [motorcycleId], references: [id], onDelete: Restrict)
  category     String
  amount       Decimal     @db.Decimal(10, 2)
  incurredAt   DateTime    @map("incurred_at") @db.Date
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("expenses")
}
